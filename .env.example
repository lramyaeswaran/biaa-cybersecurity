# =============================================================
#  KubeSentinel — Environment Variables
# =============================================================
#  Copy this file:  cp .env.example .env
#  Then fill in your API key below.
# =============================================================

# -----------------------------------------------------------
# Which LLM host to reason with. The graph is identical for all three.
#   groq          hosted, fast, default. Works in a Codespace.
#   ollama-cloud  hosted Ollama. Works in a Codespace (no GPU needed).
#   ollama-local  your laptop. Nothing leaves the machine.
# -----------------------------------------------------------
LLM_PROVIDER=groq

# -----------------------------------------------------------
# Groq API — https://console.groq.com
# Required when LLM_PROVIDER=groq
# -----------------------------------------------------------
GROQ_API_KEY=your-groq-api-key-here

# -----------------------------------------------------------
# Ollama Cloud — https://ollama.com
# Required when LLM_PROVIDER=ollama-cloud. Leave blank otherwise.
# -----------------------------------------------------------
OLLAMA_API_KEY=

# -----------------------------------------------------------
# Model overrides. Defaults are in llm.py and were verified against the live
# APIs — you should not normally need these.
#
# WARNING 1: Groq retires models on weeks of notice. llama-3.3-70b-versatile
# and llama-3.1-8b-instant are both shut down on 2026-08-16. If a scan starts
# failing with a model error, check https://console.groq.com/docs/deprecations
#
# WARNING 2: not every model can do structured output, and the agent needs it.
# gpt-oss:120b works on Groq but NOT on Ollama Cloud — same weights, different
# serving stack, and it answers in prose there. If you swap OLLAMA_CLOUD_MODEL,
# test it: `pytest` will not catch this, only a real scan will.
# -----------------------------------------------------------
# GROQ_REASON_MODEL=openai/gpt-oss-120b
# OLLAMA_CLOUD_MODEL=gemma4:31b
# OLLAMA_LOCAL_MODEL=llama3.1:8b
# OLLAMA_HOST=http://localhost:11434

# -----------------------------------------------------------
# Namespaces the dashboard offers by default.
# -----------------------------------------------------------
SCAN_NAMESPACES=vuln-demo,safe-demo

LOG_LEVEL=INFO
